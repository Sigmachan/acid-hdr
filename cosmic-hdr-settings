#!/usr/bin/env python3
"""cosmic-hdr-settings — HDR display calibration panel for COSMIC desktop"""
import gi, subprocess, os
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Adw, GLib

CONF = '/etc/cosmic-hdr.conf'
BIN  = '/usr/local/bin/cosmic-hdr'

# ── config I/O ───────────────────────────────────────────────────────────────

def read_conf():
    d = {'SDR_NITS': 203, 'PEAK_NITS': 800, 'GAMUT': 100}
    try:
        for line in open(CONF):
            k, _, v = line.strip().partition('=')
            if k in d:
                try: d[k] = int(v)
                except: pass
    except: pass
    return d

def write_conf(sdr, peak, gamut):
    txt = f'SDR_NITS={sdr}\nPEAK_NITS={peak}\nGAMUT={gamut}\n'
    subprocess.run(['sudo', 'tee', CONF], input=txt.encode(), capture_output=True)

def run_hdr(*args):
    subprocess.Popen(['sudo', BIN, *args])

def service_active():
    r = subprocess.run(['systemctl', 'is-active', 'cosmic-hdr.service'],
                       capture_output=True, text=True)
    return r.stdout.strip() == 'active'

# ── UI ───────────────────────────────────────────────────────────────────────

class HDRSettings(Adw.Application):
    def __init__(self):
        super().__init__(application_id='ru.sigmachan.CosmicHdrSettings')
        self.connect('activate', self._build)

    def _build(self, app):
        conf = read_conf()

        win = Adw.ApplicationWindow(application=app,
                                    title='Display — HDR Settings')
        win.set_default_size(520, -1)

        tb = Adw.ToolbarView()
        tb.add_top_bar(Adw.HeaderBar())

        clamp = Adw.Clamp(maximum_size=500,
                           margin_top=16, margin_bottom=24,
                           margin_start=16, margin_end=16)
        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=20)
        clamp.set_child(root)
        tb.set_content(clamp)
        win.set_content(tb)

        # ── HDR toggle ──────────────────────────────────────────────────────
        hdr_grp = Adw.PreferencesGroup(title='HDR Output')
        hdr_row = Adw.SwitchRow(title='Enable HDR10',
                                 subtitle='BT.2020 + PQ signal · cosmic-hdr.service')
        hdr_row.set_active(service_active())
        hdr_grp.add(hdr_row)
        root.append(hdr_grp)

        # ── Brightness ──────────────────────────────────────────────────────
        br_grp = Adw.PreferencesGroup(
            title='Brightness',
            description='SDR White = how bright regular desktop content appears in HDR mode. '
                        'Matches KDE "SDR Brightness". Peak = your display\'s max HDR luminance.')

        sdr_row = Adw.ActionRow(title='SDR White',
                                 subtitle=f'{conf["SDR_NITS"]} nits')
        sdr_adj = Gtk.Adjustment(value=conf['SDR_NITS'],
                                  lower=80, upper=400, step_increment=1)
        sdr_scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL,
                               adjustment=sdr_adj, draw_value=False,
                               hexpand=True, width_request=220)
        for v, l in [(100,'100'), (203,'203 ✦'), (300,'300')]:
            sdr_scale.add_mark(v, Gtk.PositionType.BOTTOM, l)
        sdr_row.add_suffix(sdr_scale)
        sdr_lbl = Gtk.Label(label=f'{conf["SDR_NITS"]}', width_chars=4)
        sdr_row.add_suffix(sdr_lbl)
        br_grp.add(sdr_row)

        peak_row = Adw.ActionRow(title='Display Peak',
                                  subtitle=f'{conf["PEAK_NITS"]} nits  (A85H OLED ≈ 800–1000)')
        peak_adj = Gtk.Adjustment(value=conf['PEAK_NITS'],
                                   lower=400, upper=1200, step_increment=10)
        peak_scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL,
                                adjustment=peak_adj, draw_value=False,
                                hexpand=True, width_request=220)
        for v, l in [(800,'800 ✦'), (1000,'1000')]:
            peak_scale.add_mark(v, Gtk.PositionType.BOTTOM, l)
        peak_row.add_suffix(peak_scale)
        peak_lbl = Gtk.Label(label=f'{conf["PEAK_NITS"]}', width_chars=5)
        peak_row.add_suffix(peak_lbl)
        br_grp.add(peak_row)

        root.append(br_grp)

        # ── Colour ──────────────────────────────────────────────────────────
        col_grp = Adw.PreferencesGroup(
            title='Colour',
            description='Gamut expansion via BT.709→BT.2020 CTM matrix (applied in linear light domain).')

        gamut_row = Adw.ActionRow(title='Gamut Expansion',
                                   subtitle='0% = sRGB identical · 100% = full BT.2020 wide colour')
        gamut_adj = Gtk.Adjustment(value=conf['GAMUT'],
                                    lower=0, upper=100, step_increment=1)
        gamut_scale = Gtk.Scale(orientation=Gtk.Orientation.HORIZONTAL,
                                 adjustment=gamut_adj, draw_value=False,
                                 hexpand=True, width_request=220)
        gamut_scale.add_mark(0,   Gtk.PositionType.BOTTOM, 'sRGB')
        gamut_scale.add_mark(100, Gtk.PositionType.BOTTOM, 'BT.2020')
        gamut_row.add_suffix(gamut_scale)
        gamut_lbl = Gtk.Label(label=f'{conf["GAMUT"]}%', width_chars=5)
        gamut_row.add_suffix(gamut_lbl)
        col_grp.add(gamut_row)

        root.append(col_grp)

        # ── live label updates ───────────────────────────────────────────────
        sdr_adj.connect('value-changed',
            lambda a: sdr_lbl.set_label(f'{int(a.get_value())}'))
        peak_adj.connect('value-changed',
            lambda a: peak_lbl.set_label(f'{int(a.get_value())}'))
        gamut_adj.connect('value-changed',
            lambda a: gamut_lbl.set_label(f'{int(a.get_value())}%'))

        # ── buttons ─────────────────────────────────────────────────────────
        btn_row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL,
                           spacing=12, halign=Gtk.Align.END)
        btn_reset = Gtk.Button(label='Reset to SDR', css_classes=['destructive-action'])
        btn_apply = Gtk.Button(label='Apply',        css_classes=['suggested-action'])
        btn_row.append(btn_reset)
        btn_row.append(btn_apply)
        root.append(btn_row)

        # ── signal wiring ────────────────────────────────────────────────────
        def apply(_=None):
            sdr  = int(sdr_adj.get_value())
            peak = int(peak_adj.get_value())
            gam  = int(gamut_adj.get_value())
            write_conf(sdr, peak, gam)
            run_hdr(f'--sdr-nits', str(sdr),
                    f'--peak-nits', str(peak),
                    f'--gamut', str(gam))
            hdr_row.set_active(True)

        def reset(_=None):
            run_hdr('reset')
            hdr_row.set_active(False)

        def on_hdr_toggle(row, _):
            if row.get_active(): apply()
            else:                reset()

        btn_apply.connect('clicked', apply)
        btn_reset.connect('clicked', reset)
        hdr_row.connect('notify::active', on_hdr_toggle)

        win.present()


HDRSettings().run(None)
